module problem3_vlg_vec_tst();
// constants                                           
// general purpose registers
reg [7:0] A;
reg [7:0] B;
reg Clock;
reg FSM_reset;
reg latchReset;
// wires                                               
wire [0:6] student_ID;
wire [0:6] yesno;

wire sampler;                             

// assign statements (if any)                          
problem3 i1 (
// port map - connection between master ports and signals/registers   
	.A(A),
	.B(B),
	.Clock(Clock),
	.FSM_reset(FSM_reset),
	.latchReset(latchReset),
	.student_ID(student_ID),
	.yesno(yesno)
);
// A[ 7 ]
initial
begin
	A[7] = 1'b0;
end 
// A[ 6 ]
initial
begin
	A[6] = 1'b0;
end 
// A[ 5 ]
initial
begin
	A[5] = 1'b0;
end 
// A[ 4 ]
initial
begin
	A[4] = 1'b0;
end 
// A[ 3 ]
initial
begin
	A[3] = 1'b0;
end 
// A[ 2 ]
initial
begin
	A[2] = 1'b1;
end 
// A[ 1 ]
initial
begin
	A[1] = 1'b1;
end 
// A[ 0 ]
initial
begin
	A[0] = 1'b0;
end 
// B[ 7 ]
initial
begin
	B[7] = 1'b0;
end 
// B[ 6 ]
initial
begin
	B[6] = 1'b1;
end 
// B[ 5 ]
initial
begin
	B[5] = 1'b1;
end 
// B[ 4 ]
initial
begin
	B[4] = 1'b0;
end 
// B[ 3 ]
initial
begin
	B[3] = 1'b0;
end 
// B[ 2 ]
initial
begin
	B[2] = 1'b1;
end 
// B[ 1 ]
initial
begin
	B[1] = 1'b1;
end 
// B[ 0 ]
initial
begin
	B[0] = 1'b0;
end 

// Clock
initial
begin
	Clock = 1'b0;
	Clock = #40000 1'b1;
	Clock = #40000 1'b0;
	Clock = #40000 1'b1;
	Clock = #40000 1'b0;
	Clock = #40000 1'b1;
	Clock = #40000 1'b0;
	Clock = #40000 1'b1;
	Clock = #40000 1'b0;
	Clock = #40000 1'b1;
	Clock = #40000 1'b0;
	Clock = #40000 1'b1;
	Clock = #40000 1'b0;
	Clock = #40000 1'b1;
	Clock = #40000 1'b0;
	Clock = #40000 1'b1;
	Clock = #40000 1'b0;
	Clock = #40000 1'b1;
	Clock = #40000 1'b0;
	Clock = #40000 1'b1;
	Clock = #40000 1'b0;
end 

// FSM_reset
initial
begin
	FSM_reset = 1'b0;
end 

// latchReset
initial
begin
	latchReset = 1'b0;
end 

problem3_vlg_sample_tst tb_sample (
	.A(A),
	.B(B),
	.Clock(Clock),
	.FSM_reset(FSM_reset),
	.latchReset(latchReset),
	.sampler_tx(sampler)
);

problem3_vlg_check_tst tb_out(
	.student_ID(student_ID),
	.yesno(yesno),
	.sampler_rx(sampler)
);
endmodule

