`timescale 1 ps/ 1 ps
module problem3_vlg_sample_tst(
	A,
	B,
	Clock,
	FSM_reset,
	latchReset,
	sampler_tx
);
input [7:0] A;
input [7:0] B;
input  Clock;
input  FSM_reset;
input  latchReset;
output sampler_tx;

reg sample;
time current_time;
always @(A or B or Clock or FSM_reset or latchReset)
                                                                                
begin                                                 
 if ($realtime > 0)                                   
 begin                                                
	if ($realtime == 0 || $realtime != current_time)  
	begin									          
		if (sample === 1'bx)                          
			sample = 0;                               
		else                                          
			sample = ~sample;                         
	end										          
	current_time = $realtime;					      
 end                                                  
end                                                   

assign sampler_tx = sample;
endmodule

module problem3_vlg_check_tst (
	student_ID,
	yesno,
	sampler_rx
);
input [0:6] student_ID;
input [0:6] yesno;
input sampler_rx;

reg [0:6] student_ID_expected;
reg [0:6] yesno_expected;

reg [0:6] student_ID_prev;
reg [0:6] yesno_prev;

reg [0:6] student_ID_expected_prev;
reg [0:6] yesno_expected_prev;

reg [0:6] last_student_ID_exp;
reg [0:6] last_yesno_exp;

reg trigger;

integer i;
integer nummismatches;

reg [1:2] on_first_change ;


initial
begin
trigger = 0;
i = 0;
nummismatches = 0;
on_first_change = 2'b1;
end

// update real /o prevs

always @(trigger)
begin
	student_ID_prev = student_ID;
	yesno_prev = yesno;
end

// update expected /o prevs

always @(trigger)
begin
	student_ID_expected_prev = student_ID_expected;
	yesno_expected_prev = yesno_expected;
end


// expected student_ID[ 6 ]
initial
begin
	student_ID_expected[6] = 1'bX;
end 
// expected student_ID[ 5 ]
initial
begin
	student_ID_expected[5] = 1'bX;
end 
// expected student_ID[ 4 ]
initial
begin
	student_ID_expected[4] = 1'bX;
