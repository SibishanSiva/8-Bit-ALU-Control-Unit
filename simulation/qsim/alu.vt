end 
// expected yesno[ 1 ]
initial
begin
	yesno_expected[1] = 1'bX;
end 
// expected yesno[ 0 ]
initial
begin
	yesno_expected[0] = 1'bX;
end 
// generate trigger
always @(student_ID_expected or student_ID or yesno_expected or yesno)
begin
	trigger <= ~trigger;
end

always @(posedge sampler_rx or negedge sampler_rx)
begin
`ifdef debug_tbench
	$display("Scanning pattern %d @time = %t",i,$realtime );
	i = i + 1;
	$display("| expected student_ID = %b | expected yesno = %b | ",student_ID_expected_prev,yesno_expected_prev);
	$display("| real student_ID = %b | real yesno = %b | ",student_ID_prev,yesno_prev);
`endif
	if (
		( student_ID_expected_prev[0] !== 1'bx ) && ( student_ID_prev[0] !== student_ID_expected_prev[0] )
		&& ((student_ID_expected_prev[0] !== last_student_ID_exp[0]) ||
			on_first_change[1])
	)
	begin
		$display ("ERROR! Vector Mismatch for output port student_ID[0] :: @time = %t",  $realtime);
